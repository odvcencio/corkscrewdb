package corkscrewdb

import (
	"context"
	"testing"
	"time"

	"github.com/odvcencio/corkscrewdb/replica"
)

unit "ReplicateAdapters_ErrorCases" {
	then "NewRPCPuller with nil db returns error" {
		puller, err := NewRPCPuller(nil)
		expect err != nil
		expect puller == nil
	}

	then "NewRPCPuller on a local non-remote DB returns error" {
		localDB, _ := openTestDB(t)
		puller, err := NewRPCPuller(localDB)
		expect err != nil
		expect puller == nil
	}

	then "NewDBApplier with nil db returns error" {
		applier, err := NewDBApplier(nil)
		expect err != nil
		expect applier == nil
	}
}

unit "ReplicateAdapters_PullSnapshot" {
	// Start primary server with data.
	serverDB, addr := startRemoteTestServer(t, WithProvider(&mockProvider{dim: 16}), WithToken("secret"))

	coll := serverDB.Collection("docs", WithBitWidth(2))
	if err := coll.Put("snap-1", Entry{Text: "snapshot entry one"}); err != nil {
		t.Fatal(err)
	}
	if err := coll.Put("snap-2", Entry{Text: "snapshot entry two"}); err != nil {
		t.Fatal(err)
	}

	// Connect and create RPCPuller.
	client, err := Connect(addr, WithToken("secret"))
	if err != nil {
		t.Fatal(err)
	}
	t.Cleanup(func() { client.Close() })

	puller, err := NewRPCPuller(client)
	if err != nil {
		t.Fatal(err)
	}

	then "PullSnapshot returns data with entries" {
		resp, err := puller.PullSnapshot(replica.SnapshotRequest{
			Collection: "docs",
		})
		expect err == nil
		expect resp.Data.Collection == "docs"
		expect len(resp.Data.Entries) >= 2
	}
}

unit "ReplicateAdapters_PullEntries" {
	// Start primary server with data.
	serverDB, addr := startRemoteTestServer(t, WithProvider(&mockProvider{dim: 16}), WithToken("secret"))

	coll := serverDB.Collection("docs", WithBitWidth(2))
	if err := coll.Put("entry-1", Entry{Text: "pull entry one"}); err != nil {
		t.Fatal(err)
	}
	if err := coll.Put("entry-2", Entry{Text: "pull entry two"}); err != nil {
		t.Fatal(err)
	}

	// Connect and create RPCPuller.
	client, err := Connect(addr, WithToken("secret"))
	if err != nil {
		t.Fatal(err)
	}
	t.Cleanup(func() { client.Close() })

	puller, err := NewRPCPuller(client)
	if err != nil {
		t.Fatal(err)
	}

	then "PullEntries since clock 0 returns all entries" {
		resp, err := puller.PullEntries(replica.PullRequest{
			Collection: "docs",
			SinceClock: 0,
			MaxEntries: 100,
		})
		expect err == nil
		expect len(resp.Entries) >= 2
	}
}

unit "ReplicateAdapters_StreamEntries" {
	// Start primary server with data.
	serverDB, addr := startRemoteTestServer(t, WithProvider(&mockProvider{dim: 16}), WithToken("secret"))

	coll := serverDB.Collection("docs", WithBitWidth(2))
	if err := coll.Put("stream-1", Entry{Text: "stream entry one"}); err != nil {
		t.Fatal(err)
	}
	if err := coll.Put("stream-2", Entry{Text: "stream entry two"}); err != nil {
		t.Fatal(err)
	}

	// Connect and create RPCPuller.
	client, err := Connect(addr, WithToken("secret"))
	if err != nil {
		t.Fatal(err)
	}
	t.Cleanup(func() { client.Close() })

	puller, err := NewRPCPuller(client)
	if err != nil {
		t.Fatal(err)
	}

	then "StreamEntries delivers entries through handler" {
		ctx, cancel := context.WithTimeout(context.Background(), 2*time.Second)
		defer cancel()

		var received []replica.Entry
		err := puller.StreamEntries(ctx, replica.PullRequest{
			Collection: "docs",
			SinceClock: 0,
			MaxEntries: 100,
		}, func(resp replica.PullResponse) error {
			received = append(received, resp.Entries...)
			return nil
		})
		// StreamEntries may return context.DeadlineExceeded after delivering entries.
		_ = err
		expect len(received) >= 2
	}
}

unit "ReplicateAdapters_DBApplier_ApplySnapshot" {
	// Start primary server with data.
	serverDB, addr := startRemoteTestServer(t, WithProvider(&mockProvider{dim: 16}), WithToken("secret"))

	coll := serverDB.Collection("docs", WithBitWidth(2))
	if err := coll.Put("apply-1", Entry{Text: "apply snapshot one"}); err != nil {
		t.Fatal(err)
	}
	if err := coll.Put("apply-2", Entry{Text: "apply snapshot two"}); err != nil {
		t.Fatal(err)
	}

	// Connect and pull snapshot.
	client, err := Connect(addr, WithToken("secret"))
	if err != nil {
		t.Fatal(err)
	}
	t.Cleanup(func() { client.Close() })

	puller, err := NewRPCPuller(client)
	if err != nil {
		t.Fatal(err)
	}

	snapResp, err := puller.PullSnapshot(replica.SnapshotRequest{Collection: "docs"})
	if err != nil {
		t.Fatal(err)
	}

	then "ApplySnapshot loads data into local DB and makes it searchable" {
		localDB, _ := openTestDB(t)
		applier, err := NewDBApplier(localDB)
		expect err == nil

		err = applier.ApplySnapshot(snapResp.Data)
		expect err == nil

		localColl := localDB.Collection("docs")
		results, err := localColl.Search("apply snapshot one", 5)
		expect err == nil
		expect len(results) > 0
	}
}

unit "ReplicateAdapters_DBApplier_ApplyReplicatedEntry" {
	// Start primary server with data.
	serverDB, addr := startRemoteTestServer(t, WithProvider(&mockProvider{dim: 16}), WithToken("secret"))

	coll := serverDB.Collection("docs", WithBitWidth(2))
	if err := coll.Put("rep-entry-1", Entry{Text: "replicated entry text"}); err != nil {
		t.Fatal(err)
	}

	// Pull entries via RPCPuller.
	client, err := Connect(addr, WithToken("secret"))
	if err != nil {
		t.Fatal(err)
	}
	t.Cleanup(func() { client.Close() })

	puller, err := NewRPCPuller(client)
	if err != nil {
		t.Fatal(err)
	}

	pullResp, err := puller.PullEntries(replica.PullRequest{
		Collection: "docs",
		SinceClock: 0,
		MaxEntries: 100,
	})
	if err != nil {
		t.Fatal(err)
	}

	then "ApplyReplicatedEntry applies each pulled entry to local DB" {
		localDB, _ := openTestDB(t)
		applier, err := NewDBApplier(localDB)
		expect err == nil

		for _, entry := range pullResp.Entries {
			err := applier.ApplyReplicatedEntry("docs", entry)
			expect err == nil
		}

		localColl := localDB.Collection("docs")
		h, err := localColl.History("rep-entry-1")
		expect err == nil
		expect len(h) == 1
		expect h[0].Text == "replicated entry text"
	}
}

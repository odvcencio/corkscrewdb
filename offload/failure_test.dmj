package offload

import (
	"bytes"
	"errors"
	"io"
	"os"
	"path/filepath"
	"testing"
	"time"
)

type failBackend struct {
	pushErr error
	listErr error
}

func (b *failBackend) Push(key string, reader io.Reader) error { return b.pushErr }
func (b *failBackend) List(prefix string) ([]string, error)   { return nil, b.listErr }
func (b *failBackend) Pull(key string, writer io.Writer) error { return nil }
func (b *failBackend) Delete(key string) error                 { return nil }

unit "BackendPushError" {
	then "push returns configured error" {
		fb := &failBackend{pushErr: errors.New("disk full")}
		err := fb.Push("some/key", bytes.NewReader([]byte("data")))
		expect err != nil
		if err != nil && err.Error() != "disk full" {
			t.Errorf("expected 'disk full', got: %v", err)
		}
	}
}

unit "IdempotentPush" {
	then "pushing same key twice yields exactly one list entry" {
		root := t.TempDir()
		b := NewFSBackend(root)
		data := []byte("payload")
		err := b.Push("seg/000001.wal", bytes.NewReader(data))
		expect err == nil
		err = b.Push("seg/000001.wal", bytes.NewReader(data))
		expect err == nil
		keys, err := b.List("seg/000001.wal")
		expect err == nil
		expect len(keys) == 1
	}
}

unit "ManagerStartStop" {
	then "Start triggers push loop and Stop drains it cleanly" {
		dbDir := t.TempDir()
		coldDir := t.TempDir()

		// Create collection with a sealed WAL segment and an active one.
		walDir := filepath.Join(dbDir, "collections", "col1", "wal")
		if err := os.MkdirAll(walDir, 0o755); err != nil {
			t.Fatal(err)
		}
		if err := os.WriteFile(filepath.Join(walDir, "000001.wal"), []byte("sealed"), 0o644); err != nil {
			t.Fatal(err)
		}
		if err := os.WriteFile(filepath.Join(walDir, "000002.wal"), []byte("active"), 0o644); err != nil {
			t.Fatal(err)
		}
		// Add a snapshot.
		collDir := filepath.Join(dbDir, "collections", "col1")
		if err := os.WriteFile(filepath.Join(collDir, "snapshot-00001.csdb"), []byte("snap"), 0o644); err != nil {
			t.Fatal(err)
		}

		mgr, err := NewManager(Config{
			Backend:  NewFSBackend(coldDir),
			DBPath:   dbDir,
			Interval: 50 * time.Millisecond,
		})
		expect err == nil

		mgr.Start()
		// Wait long enough for at least two tick cycles.
		time.Sleep(200 * time.Millisecond)
		mgr.Stop()

		// Sealed WAL must be in cold storage.
		_, err = os.Stat(filepath.Join(coldDir, "collections", "col1", "wal", "000001.wal"))
		expect err == nil

		// Active WAL must NOT be in cold storage.
		_, notPushed := os.Stat(filepath.Join(coldDir, "collections", "col1", "wal", "000002.wal"))
		expect os.IsNotExist(notPushed)

		// Snapshot must be in cold storage.
		_, err = os.Stat(filepath.Join(coldDir, "collections", "col1", "snapshot-00001.csdb"))
		expect err == nil
	}
}

unit "ManagerStartIdempotent" {
	then "calling Start twice does not panic and produces only one push loop" {
		dbDir := t.TempDir()
		coldDir := t.TempDir()

		mgr, err := NewManager(Config{
			Backend:  NewFSBackend(coldDir),
			DBPath:   dbDir,
			Interval: 50 * time.Millisecond,
		})
		expect err == nil

		// Start twice — second call must be a no-op, not a panic.
		mgr.Start()
		mgr.Start()

		time.Sleep(80 * time.Millisecond)
		mgr.Stop()
		expect true
	}
}

unit "ManagerStopBeforeStart" {
	then "Stop without Start does not panic or block" {
		dbDir := t.TempDir()
		coldDir := t.TempDir()

		mgr, err := NewManager(Config{
			Backend:  NewFSBackend(coldDir),
			DBPath:   dbDir,
			Interval: 50 * time.Millisecond,
		})
		expect err == nil

		// Stop before Start must return immediately without panic.
		done := make(chan struct{})
		go func() {
			defer close(done)
			mgr.Stop()
		}()

		select {
		case <-done:
			// good
		case <-time.After(500 * time.Millisecond):
			t.Fatal("Stop() blocked when called before Start()")
		}
	}
}
